# Required in production. Development falls back to admin for local use.
ADMIN_PASSWORD=admin
SESSION_SECRET=replace-with-a-long-random-value

# Public origin for the Node adapter. The /frisbee base path is configured at build time.
ORIGIN=https://jspeicher.com

# Relative paths resolve from the web process working directory.
UVS_DATABASE_PATH=./data/ultimate-video-stats.sqlite

# Accommodates the application-level 128 MiB metadata upload limit.
BODY_SIZE_LIMIT=134217728
